{
  "name": "ai-toolkit-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n WORKER,UI \"ts-node-dev --project tsconfig.worker.json --respawn --watch cron --transpile-only cron/worker.ts\" \"next dev --turbopack\"",
    "build": "tsc -p tsconfig.worker.json && next build",
    "start": "concurrently -n WORKER,UI \"node dist/cron/worker.js\" \"node scripts/start-ui.js\"",
    "build_and_start": "npm run update_db && npm run build && npm run start",
    "lint": "next lint",
    "update_db": "prisma db push",
    "generate_prisma": "prisma generate",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,css,scss}\""
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "5.22.0",
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "classnames": "^2.5.1",
    "lucide-react": "^0.475.0",
    "next": "^13.5.11",
    "node-cache": "^5.1.2",
    "prisma": "5.22.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.3.5",
    "react-global-hooks": "^1.3.5",
    "react-icons": "^5.5.0",
    "react-select": "^5.10.1",
    "recharts": "^3.6.0",
    "sqlite3": "^5.1.7",
    "systeminformation": "^5.27.11",
    "uuid": "^11.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.1.2",
    "postcss": "^8",
    "prettier": "^3.5.1",
    "prettier-basic": "^1.0.0",
    "tailwindcss": "^3.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5"
  },
  "prettier": "prettier-basic"
}
