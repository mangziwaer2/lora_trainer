{
  "job": "extension",
  "config": {
    "name": "kaggle_sdxl_lora",
    "process": [
      {
        "type": "diffusion_trainer",
        "training_folder": "E:\\project\\loraTrainer\\compressed\\ai-toolkit\\ai-toolkit-output",
        "sqlite_db_path": "E:\\project\\loraTrainer\\compressed\\ai-toolkit\\aitk_db.db",
        "device": "cuda",
        "trigger_word": null,
        "performance_log_every": 10,
        "disable_progress_bar": false,
        "progress_bar_mininterval": 1.0,
        "network": {
          "type": "lora",
          "linear": 32,
          "linear_alpha": 32,
          "conv": 16,
          "conv_alpha": 16,
          "lokr_full_rank": true,
          "lokr_factor": -1,
          "network_kwargs": {
            "ignore_if_contains": []
          }
        },
        "save": {
          "dtype": "float16",
          "save_every": 250,
          "save_best_model": true,
          "max_step_saves_to_keep": 20,
          "save_format": "safetensors",
          "push_to_hub": false
        },
        "datasets": [
          {
            "folder_path": "E:\\IDrawing\\ComfyUI-aki-v1.7\\ComfyUI\\output\\lora_enc",
            "cache_dir": "E:\\project\\loraTrainer\\compressed\\ai-toolkit\\ai-toolkit-output\\kaggle_sdxl_lora\\dataset_cache",
            "mask_path": null,
            "mask_min_value": 0.1,
            "default_caption": "",
            "caption_ext": "txt",
            "decode_images": true,
            "decode_key": 123456789,
            "caption_dropout_rate": 0.05,
            "cache_latents": false,
            "cache_latents_to_disk": false,
            "num_workers": 2,
            "prefetch_factor": 2,
            "is_reg": false,
            "network_weight": 1,
            "resolution": [
              512,
              768,
              1024
            ],
            "controls": [],
            "shrink_video_to_frames": false,
            "num_frames": 1,
            "do_i2v": false,
            "flip_x": false,
            "flip_y": false
          }
        ],
        "train": {
          "batch_size": 2,
          "bypass_guidance_embedding": false,
          "steps": 20000,
          "gradient_accumulation": 1,
          "train_unet": true,
          "train_text_encoder": false,
          "gradient_checkpointing": true,
          "noise_scheduler": "ddpm",
          "optimizer": "adamw8bit",
          "timestep_type": "sigmoid",
          "content_or_style": "balanced",
          "optimizer_params": {
            "weight_decay": 0.0001
          },
          "unload_text_encoder": false,
          "cache_text_embeddings": false,
          "lr": 0.0001,
          "ema_config": {
            "use_ema": false,
            "ema_decay": 0.99
          },
          "skip_first_sample": true,
          "force_first_sample": false,
          "disable_sampling": false,
          "dtype": "fp16",
          "diff_output_preservation": false,
          "diff_output_preservation_multiplier": 1.0,
          "diff_output_preservation_class": "person",
          "switch_boundary_every": 1,
          "loss_type": "mse"
        },
        "logging": {
          "log_every": 1,
          "use_ui_logger": false
        },
        "model": {
          "name_or_path": "E:\\IDrawing\\forge7\\models\\Stable-diffusion\\bespokeillmix_v10.safetensors",
          "quantize": false,
          "qtype": "qfloat8",
          "quantize_te": false,
          "qtype_te": "qfloat8",
          "arch": "sdxl",
          "low_vram": false,
          "model_kwargs": {}
        },
        "sample": {
          "sampler": "ddpm",
          "sample_every": 250,
          "width": 1024,
          "height": 1024,
          "samples": [
            {
              "prompt": "1girl, anime coloring,dress,sfw,posing,embarrassed,thighhighs,"
            },
            {
              "prompt": "1girl,anime coloring,maid,sfw,off shoulder,strapless,miniskirt,embarrassed,clothes,pull,loose socks,pose,dynamic emotion,"
            }
          ],
          "neg": "",
          "seed": 42,
          "walk_seed": true,
          "guidance_scale": 2.0,
          "sample_steps": 20,
          "num_frames": 1,
          "fps": 1
        }
      }
    ]
  },
  "meta": {
    "name": "[name]",
    "version": "1.0"
  }
}